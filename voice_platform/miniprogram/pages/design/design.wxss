.text-input {
  border: 2rpx solid #d1d5db;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  min-height: 140rpx;
  background: #fff;
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.audio-bar {
  background: #f0fdf4;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.audio-label {
  font-size: 26rpx;
  color: #16a34a;
}

.play-btn {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: #fff;
  border: 2rpx solid #d1d5db;
}

.btn-design {
  background: #0891b2;
}
