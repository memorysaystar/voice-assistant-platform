<view class="container">
  <view class="header">
    <text class="title">语音助手</text>
    <text class="subtitle">登录 / Sign In</text>
  </view>

  <view class="form">
    <input class="input-field" placeholder="邮箱 / Email" value="{{email}}" bindinput="onEmailInput" type="text" />
    <input class="input-field" placeholder="密码 / Password" value="{{password}}" bindinput="onPasswordInput" password="true" />
    <button class="btn-primary" bindtap="onLogin" loading="{{loading}}" disabled="{{loading}}">登录</button>
    <view wx:if="{{debugLog}}" class="debug-log">
      <text class="debug-text">{{debugLog}}</text>
    </view>
    <view class="link" bindtap="goRegister">
      <text class="link-text">没有账号？注册</text>
    </view>
  </view>
</view>
