<view class="container">
  <view class="header">
    <text class="title">对话历史</text>
    <view class="new-btn" bindtap="onNewChat">
      <text class="new-btn-text">+ 新对话</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{conversations.length === 0}}" class="empty">
    <text class="empty-text">暂无对话</text>
    <text class="empty-hint">点击右上角开始新对话</text>
  </view>

  <view wx:else class="list">
    <view
      wx:for="{{conversations}}"
      wx:key="id"
      class="conv-item"
      bindtap="onTapConv"
      data-id="{{item.id}}"
      bindlongpress="onLongPress"
    >
      <view class="conv-info">
        <text class="conv-title">{{item.title || '新对话'}}</text>
        <text class="conv-meta">{{item.message_count || 0}} 条消息</text>
      </view>
      <text class="conv-arrow">›</text>
    </view>
  </view>
</view>
