.container {
  padding: 30rpx;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
}

.new-btn {
  background: #2563eb;
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
}

.new-btn-text {
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
}

.empty-hint {
  font-size: 26rpx;
  color: #9ca3af;
  margin-top: 12rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.conv-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.conv-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.conv-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.conv-meta {
  font-size: 24rpx;
  color: #9ca3af;
}

.conv-arrow {
  font-size: 40rpx;
  color: #d1d5db;
}
