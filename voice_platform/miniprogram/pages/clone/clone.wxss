.source-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.source-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #f9fafb;
}

.source-btn-recording {
  border-color: #fca5a5;
  background: #fef2f2;
}

.source-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.source-text {
  font-size: 26rpx;
  color: #374151;
}

.file-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f0fdf4;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.file-icon {
  font-size: 32rpx;
}

.file-name {
  font-size: 26rpx;
  color: #16a34a;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-input {
  border: 2rpx solid #d1d5db;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  min-height: 160rpx;
  background: #fff;
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.audio-bar {
  background: #f0fdf4;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.audio-label {
  font-size: 26rpx;
  color: #16a34a;
}

.play-btn {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: #fff;
  border: 2rpx solid #d1d5db;
}

.btn-clone {
  background: #7c3aed;
}
