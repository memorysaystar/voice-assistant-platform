.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 30rpx;
  display: block;
}

.server-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 12rpx;
}

.input-flex {
  flex: 1;
}

.apply-btn {
  background: #2563eb;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.apply-text {
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.info-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 20rpx;
}

.info-text {
  font-size: 26rpx;
  color: #9ca3af;
}
