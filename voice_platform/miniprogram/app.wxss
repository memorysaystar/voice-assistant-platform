/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #1f2937;
  background-color: #f5f5f5;
}

.container {
  padding: 30rpx;
}

.btn-primary {
  background-color: #2563eb;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-danger {
  background-color: #dc2626;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.input-field {
  border: 2rpx solid #d1d5db;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  color: #1f2937;
  background: #fff;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}
